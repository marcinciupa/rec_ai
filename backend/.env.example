# Skopiuj do .env i uzupełnij. .env jest gitignored.
ENVIRONMENT=development
LOG_LEVEL=INFO
API_CORS_ORIGINS=*

# Publiczny URL backendu — żeby deAPI mogło dosięgnąć webhooka.
# Lokalnie użyj tunelu (cloudflared/ngrok) i wstaw jego adres:
# API_PUBLIC_URL=https://twoj-tunel.trycloudflare.com

# ── deAPI (transkrypcja) ──
DEAPI_API_KEY=
DEAPI_WEBHOOK_SECRET=
# Do JEDNORAZOWEGO podejrzenia payloadu deAPI można skierować webhook na webhook.site:
# DEAPI_WEBHOOK_URL_OVERRIDE=https://webhook.site/xxxxxxxx

# ── OpenRouter (czat) ──
OPENROUTER_API_KEY=
